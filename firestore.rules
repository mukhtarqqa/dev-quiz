rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Функция проверки, является ли пользователь админом
    // В React-приложении ADMIN_EMAILS прописаны в константах, 
    // здесь мы можем продублировать логику или проверять кастомные клеймы.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'minamuha2020@gmail.com' || 
        request.auth.token.email == 'toph89573@gmail.com' || 
        request.auth.token.email == 'chikibanboni01@gmail.com'
      );
    }

    // Динамические тесты
    match /dynamic_tests/{testId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Баг-репорты
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, delete: if isAdmin();
    }

    // Пользователи (доступ к тестам)
    match /users/{email} {
      allow read: if request.auth != null && (request.auth.token.email == email || isAdmin());
      allow create: if request.auth != null && request.auth.token.email == email && 
                    (request.resource.data.hasAccess == false || isAdmin());
      // Пользователь может обновлять только поле devices, админ — всё
      allow update: if isAdmin() || (
        request.auth != null &&
        request.auth.token.email == email &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['devices', 'lastLogin', 'picture', 'name'])
      );
    }
    
    // Статистика пользователей (если решите перенести из localStorage в будущем)
    match /user_stats/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
